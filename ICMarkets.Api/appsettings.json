{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Polling": {
    "Enabled": true,
    "IntervalSeconds": 60
  },
  "BlockCypher": {
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "Token": null,
    "RateLimitTokenLimit": 3,
    "RateLimitTokensPerPeriod": 3,
    "RateLimitReplenishmentSeconds": 1,
    "RateLimitQueueLimit": 100
  },
  "ConnectionStrings": {
    "Default": "Data Source=icmarkets.db"
  },
  "Cors": {
    "AllowedOrigins": []
  }
}
